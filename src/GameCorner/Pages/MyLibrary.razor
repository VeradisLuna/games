@page "/my-library"
@using GameCorner.Services
@inject Persistence Persistence
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="homepage">
    <h1 class="title">LunaMini.io</h1>
    <nav class="top-bar">
        <div class="top-row">
            <a href="/about">✨ about me ✨</a>
            <span class="divider">|</span>
            <a href="https://instagram.com/lunamini.io" target="_blank" rel="noopener noreferrer">Instagram</a>
            <span class="divider">|</span>
            <a href="https://ko-fi.com/veradisluna" target="_blank" rel="noopener noreferrer" title="Support me on Ko-Fi to help keep this free project going!">buy me a cuppa!</a>
            <span class="divider">|</span>
            <a href="https://tally.so/r/3j1g9E" target="_blank" rel="noopener noreferrer" title="Get in touch with me using this super simple form!">give feedback</a>
            <span class="divider">|</span>
            <a href="/my-library" title="Find puzzle packs you've played before">my library</a>
        </div>
    </nav>
    <p class="subtitle">My library</p>
    <p>These are all the packs you've played before.</p>
    <hr />
    <div class="game-grid">
        @if (unlocked_videoGames)
        {
            <div class="game-card">
                <a href="pack-video-games">
                    <div class="card-content">
                        <h2>⭐ Video games</h2>
                        <p>5 mini crosswords</p>
                    </div>
                </a>
            </div>
        }
        @if (unlocked_iceJumper)
        {
            <div class="game-card">
                <a href="ice-jumper">
                    <div class="card-content">
                        <h2>✨ Welsh ICE Christmas Jumper Day</h2>
                        <p>4 festive puzzles</p>
                    </div>
                </a>
            </div>
        }
        @if (unlocked_catchEmAll)
        {
            <div class="game-card">
                <a href="pack-pokemon-1">
                    <div class="card-content">
                        <h2>Can you catch 'em all?</h2>
                        <p>4 Pokémon-themed Hexicon puzzles</p>
                    </div>
                </a>
            </div>
        }
        @if (unlocked_hiddenRules)
        {
            <div class="game-card">
                <a href="pack-hidden-rules-1">
                    <div class="card-content">
                        <h2>Hidden rules</h2>
                        <p>5 mini crosswords</p>
                    </div>
                </a>
            </div>
        }
        @if (unlocked_schoolSubjects)
        {
            <div class="game-card">
                <a href="pack-school-1">
                    <div class="card-content">
                        <h2>School subjects</h2>
                        <p>5 mini crosswords</p>
                    </div>
                </a>
            </div>
        }
    </div>
</div>
@code{
    bool unlocked_iceJumper = false;

    bool unlocked_videoGames = false;

    bool unlocked_catchEmAll = false;
    bool unlocked_hiddenRules = false;
    bool unlocked_schoolSubjects = false;

    protected override async Task OnInitializedAsync()
    {
        await ProcessNewUnlocks();

        unlocked_iceJumper = await Persistence.CollectionUnlocked("ice-jumper");

        unlocked_videoGames = await Persistence.CollectionUnlocked("video-games");

        unlocked_catchEmAll = await Persistence.CollectionUnlocked("pokemon");
        unlocked_hiddenRules = await Persistence.CollectionUnlocked("hidden-rules");
        unlocked_schoolSubjects = await Persistence.CollectionUnlocked("school-subjects");

        if (DateOnly.FromDateTime(DateTime.Now) >= new DateOnly(2025, 12, 1) && DateOnly.FromDateTime(DateTime.Now) <= new DateOnly(2025, 12, 31))
        {
            await JS.InvokeVoidAsync("setWinterTheme", true);
            await JS.InvokeVoidAsync("miniConfetti.snow");
        }
        else
        {
            await JS.InvokeVoidAsync("setWinterTheme", false);
            await JS.InvokeVoidAsync("miniConfetti.stopSnow");
        }
    }

    private async Task ProcessNewUnlocks()
    {
        var uri = new Uri(Nav.Uri);
        var query = uri.Query; // e.g. "?unlock=diamond-geezer"

        if (string.IsNullOrWhiteSpace(query)) return;

        var parts = query.TrimStart('?')
                         .Split('&', StringSplitOptions.RemoveEmptyEntries);

        foreach (var part in parts)
        {
            var kv = part.Split('=', 2);
            if (kv.Length == 2 && kv[0] == "unlock")
            {
                switch (kv[1])
                {
                    case "diamond-geezer":
                        await Persistence.UnlockCollectionAsync("video-games");
                        break;
                }
                Nav.NavigateTo("/my-library", replace: true);
            }
        }
        return;
    }
}
