        <div class="game-card">
            <div class="progress-badge @BadgeClass(progress_puzzle2)">
                @BadgeSymbol(progress_puzzle2)
            </div>
            <a href="mini/2025-10-26?nonav=true">
                <div class="card-content">
                    <h2>Ad astra</h2>
                </div>
            </a>
        </div>
        <div class="game-card">
            <div class="progress-badge @BadgeClass(progress_puzzle3)">
                @BadgeSymbol(progress_puzzle3)
            </div>
            <a href="mini/2025-11-19?nonav=true">
                <div class="card-content">
                    <h2>Written in the stars</h2>
                </div>
            </a>
        </div>
        <div class="game-card">
            <div class="progress-badge @BadgeClass(progress_puzzle4)">
                @BadgeSymbol(progress_puzzle4)
            </div>
            <a href="mini/2025-12-02?nonav=true">
                <div class="card-content">
                    <h2>Moon landing</h2>
                </div>
            </a>
        </div>
        <div class="game-card">
            <div class="progress-badge @BadgeClass(progress_puzzle5)">
                @BadgeSymbol(progress_puzzle5)
            </div>
            <a href="mini/2026-02-03?nonav=true">
                <div class="card-content">
                    <h2>Worlds apart</h2>
                </div>
            </a>
        </div>
    </div>
</div>

@code {
    private int progress_puzzle1;
    private int progress_puzzle2;
    private int progress_puzzle3;
    private int progress_puzzle4;
    private int progress_puzzle5;

    private string letterheadTitle = "?????";
    private string hexiconTitle = "???????";

    protected override async Task OnInitializedAsync()
    {
        if (UnlockParam())
        {
            await Persistence.UnlockCollectionAsync("space");
            Nav.NavigateTo("/pack-space-1", replace: true);
        }

        if(!await Persistence.CollectionUnlocked("space"))
        {
            Nav.NavigateTo("/", replace: true);
        }

        if (DateOnly.FromDateTime(DateTime.Now) >= new DateOnly(2025, 12, 1) && DateOnly.FromDateTime(DateTime.Now) <= new DateOnly(2025, 12, 31))
        {
            await JS.InvokeVoidAsync("setWinterTheme", true);
            await JS.InvokeVoidAsync("miniConfetti.snow");
        }
        else
        {
            await JS.InvokeVoidAsync("setWinterTheme", false);
            await JS.InvokeVoidAsync("miniConfetti.stopSnow");
        }

        (progress_puzzle1, _) = await ProgressChecker.GetProgressAsync("lunamini", new DateOnly(2025, 10, 07));
        (progress_puzzle2, _) = await ProgressChecker.GetProgressAsync("lunamini", new DateOnly(2025, 10, 26));
        (progress_puzzle3, _) = await ProgressChecker.GetProgressAsync("lunamini", new DateOnly(2025, 11, 19));
        (progress_puzzle4, _) = await ProgressChecker.GetProgressAsync("lunamini", new DateOnly(2025, 12, 02));
        (progress_puzzle5, _) = await ProgressChecker.GetProgressAsync("lunamini", new DateOnly(2026, 02, 03));
    }

    private string BadgeClass(int progress) => progress switch
    {
        3 => "badge-done",
        2 => "badge-done",
        1 => "badge-started",
        _ => "badge-hidden"
    };

    private string BadgeSymbol(int progress) => progress switch
    {
        3 => "✔",
        2 => "✔",
        1 => "…",
        _ => ""
    };

    private static string Indicator(int p) => p switch
    {
        3 => " (✔)",
        2 => " (✔)",
        1 => " (…)",
        _ => ""
    };

    private bool UnlockParam()
    {
        var uri = new Uri(Nav.Uri);
        var query = uri.Query; // e.g. "?unlock=true"

        if (string.IsNullOrWhiteSpace(query)) return false;

        var parts = query.TrimStart('?')
                         .Split('&', StringSplitOptions.RemoveEmptyEntries);

        foreach (var part in parts)
        {
            var kv = part.Split('=', 2);
            if (kv.Length == 2 && kv[0] == "unlock" && kv[1] == "true")
                return true;
        }
        return false;
    }
}
